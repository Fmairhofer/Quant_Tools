    "axes[1].set_ylabel('Top 3 PC Variance (%)')\n",
    "axes[1].set_title('Rolling Variance Captured by Top 3 Components', fontsize=12, fontweight='bold')\n",
    "axes[1].legend()\n",
    "\n",
